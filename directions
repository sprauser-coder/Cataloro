# CATALORO MARKETPLACE - CENTRALIZED CONFIGURATION
# ================================================
# This file contains ALL paths, ports, URLs and configuration variables
# Update ONLY this file to change system-wide settings

# SYSTEM PATHS
APP_ROOT=/app
BACKEND_DIR=/app/backend
FRONTEND_DIR=/app/frontend
UPLOADS_DIR=/app/backend/uploads
NODE_MODULES_DIR=/app/frontend/node_modules

# DATABASE CONFIGURATION
MONGO_URL=mongodb://127.0.0.1:27017/cataloro
DB_NAME=cataloro_production
MONGO_HOST=127.0.0.1
MONGO_PORT=27017

# SERVER CONFIGURATION  
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
FRONTEND_PORT=3000

# URLs AND ENDPOINTS - PREVIEW ENVIRONMENT
PREVIEW_FRONTEND_URL=https://cataloro-hub.preview.emergentagent.com
PREVIEW_BACKEND_URL=https://cataloro-hub.preview.emergentagent.com
PRODUCTION_IP=217.154.0.82
BACKEND_URL_PRODUCTION=http://217.154.0.82
BACKEND_URL_LOCAL=http://localhost:8001
FRONTEND_URL_LOCAL=http://localhost:3000

# CURRENT ACTIVE URLs (Change these to switch environments)
ACTIVE_FRONTEND_URL=https://cataloro-hub.preview.emergentagent.com
ACTIVE_BACKEND_URL=https://cataloro-hub.preview.emergentagent.com
ACTIVE_CORS_ORIGINS=https://cataloro-hub.preview.emergentagent.com,http://localhost:3000,http://localhost:8001

# API CONFIGURATION
API_PREFIX=/api
JWT_SECRET=cataloro-dev-secret-key

# SUPERVISOR CONFIGURATION
SUPERVISOR_BACKEND_LOG=/var/log/supervisor/backend.out.log
SUPERVISOR_BACKEND_ERR_LOG=/var/log/supervisor/backend.err.log
SUPERVISOR_FRONTEND_LOG=/var/log/supervisor/frontend.out.log
SUPERVISOR_FRONTEND_ERR_LOG=/var/log/supervisor/frontend.err.log

# ENVIRONMENT SETTINGS
ENVIRONMENT=preview
APP_VERSION=1.6.5
APP_NAME=Cataloro

# AUTHENTICATION
ADMIN_EMAIL=admin@marketplace.com  
ADMIN_PASSWORD=admin123
ACCESS_TOKEN_EXPIRE_MINUTES=480

# FILE UPLOAD SETTINGS
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_EXTENSIONS=jpg,jpeg,png,gif,webp
ALLOWED_EXCEL_EXTENSIONS=xlsx,xls

# CATALYST DATABASE SETTINGS
CATALYST_COLLECTION=catalyst_items
CATALYST_BASIS_COLLECTION=catalyst_basis
CATALYST_REQUIRED_COLUMNS=cat_id,pt_ppm,pd_ppm,rh_ppm,ceramic_weight,name

# DEPLOYMENT SETTINGS
DEPLOYMENT_USER=root
DEPLOYMENT_HOST=my-vps
DEPLOYMENT_PATH=/var/www/cataloro

# TESTING SETTINGS
TEST_TIMEOUT=30
TEST_USER_EMAIL=test@marketplace.com
TEST_USER_PASSWORD=test123

# DEVELOPMENT vs PRODUCTION FLAG
# Set to 'development' for local development, 'preview' for preview env, 'production' for live deployment
DEPLOYMENT_MODE=preview

# BACKUP SETTINGS
BACKUP_DIR=/app/backups
DATABASE_BACKUP_PREFIX=cataloro_backup
LOG_RETENTION_DAYS=7

# PERFORMANCE SETTINGS
MAX_WORKERS=1
RELOAD_ON_CHANGE=true
LOG_LEVEL=INFO

# SECURITY SETTINGS
HTTPS_ONLY=true
SECURE_COOKIES=true
SESSION_TIMEOUT=28800

# INTEGRATION SETTINGS
EMERGENT_INTEGRATION_URL=https://integrations.emergentagent.com
PLUGIN_VENV_PATH=/opt/plugins-venv

# MONITORING SETTINGS
HEALTH_CHECK_ENDPOINT=/health
METRICS_ENDPOINT=/metrics
STATUS_CHECK_INTERVAL=60

# ERROR HANDLING
ERROR_LOG_MAX_SIZE=10485760
ERROR_REPORTING_ENABLED=true
DEBUG_MODE=false

# CACHE SETTINGS
REDIS_ENABLED=false
CACHE_TTL=3600
STATIC_CACHE_TTL=86400

# EMAIL SETTINGS (if needed)
SMTP_HOST=localhost
SMTP_PORT=587
EMAIL_FROM=noreply@cataloro.com

# PAYMENT SETTINGS (if needed)
PAYMENT_GATEWAY=stripe
CURRENCY=EUR
TAX_RATE=0.19

# FEATURE FLAGS
ENABLE_REGISTRATION=true
ENABLE_GUEST_CHECKOUT=false
ENABLE_REVIEWS=true
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
ENABLE_CATALYST_DATABASE=true

# LOCALIZATION
DEFAULT_LANGUAGE=en
DEFAULT_TIMEZONE=UTC
DATE_FORMAT=YYYY-MM-DD
TIME_FORMAT=HH:mm:ss

# API RATE LIMITING
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
RATE_LIMIT_ENABLED=false

# SEARCH SETTINGS
SEARCH_RESULTS_PER_PAGE=20
MAX_SEARCH_RESULTS=100
SEARCH_TIMEOUT=5000

# IMAGE PROCESSING
IMAGE_QUALITY=80
IMAGE_MAX_WIDTH=1200
IMAGE_MAX_HEIGHT=1200
THUMBNAIL_SIZE=300

# MAINTENANCE MODE
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System under maintenance

# ================================================
# END OF CONFIGURATION
